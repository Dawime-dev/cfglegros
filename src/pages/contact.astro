---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<BaseLayout
  title="Contact | CLG F. Legros"
  description="Contactez l'équipe CLG F. Legros pour toute question, suggestion ou partenariat."
>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <Breadcrumb items={[{ label: 'Contact' }]} />

    <div class="mb-8">
      <span class="text-primary-600 font-semibold text-sm uppercase tracking-wider">Contact</span>
      <h1 class="font-display text-3xl md:text-4xl font-extrabold text-navy-800 tracking-tight mt-1">Nous contacter</h1>
    </div>

    <div class="prose max-w-none mb-10">
      <p>
        Vous avez une question, une suggestion d'article ou souhaitez proposer un partenariat ?
        N'hésitez pas à nous écrire via le formulaire ci-dessous ou par email.
      </p>
    </div>

    <form class="space-y-6 bg-white p-8 rounded-2xl border border-slate-200/60 shadow-sm">
      <div>
        <label for="name" class="block text-sm font-medium text-slate-700 mb-1">Nom</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors"
          placeholder="Votre nom"
        />
      </div>

      <div>
        <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors"
          placeholder="votre@email.fr"
        />
      </div>

      <div>
        <label for="subject" class="block text-sm font-medium text-slate-700 mb-1">Sujet</label>
        <select
          id="subject"
          name="subject"
          class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors"
        >
          <option value="question">Question générale</option>
          <option value="suggestion">Suggestion d'article</option>
          <option value="partenariat">Partenariat</option>
          <option value="correction">Signaler une erreur</option>
          <option value="autre">Autre</option>
        </select>
      </div>

      <div>
        <label for="message" class="block text-sm font-medium text-slate-700 mb-1">Message</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full px-4 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 outline-none transition-colors resize-y"
          placeholder="Votre message..."
        ></textarea>
      </div>

      <button
        type="submit"
        class="bg-primary-600 text-white font-semibold px-6 py-3 rounded-lg hover:bg-primary-700 transition-colors"
      >
        Envoyer le message
      </button>
    </form>
  </div>
</BaseLayout>
