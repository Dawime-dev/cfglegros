---
interface Props {
  title: string;
  subtitle: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  title,
  subtitle,
  ctaText = 'Découvrir nos articles',
  ctaHref = '/articles',
} = Astro.props;
---

<section class="relative overflow-hidden bg-navy-900 py-20 md:py-32">
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-[0.07]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 32px 32px;"></div>
  <!-- Gradient orbs -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-primary-500/20 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
  <div class="absolute bottom-0 left-0 w-80 h-80 bg-accent-500/15 rounded-full blur-3xl translate-y-1/2 -translate-x-1/4"></div>

  <div class="relative max-w-5xl mx-auto px-4 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/10 text-primary-300 text-sm font-medium px-4 py-1.5 rounded-full mb-8">
      <span class="w-2 h-2 bg-primary-400 rounded-full animate-pulse"></span>
      Métiers &bull; Formations &bull; Écoles
    </div>

    <h1 class="font-display text-4xl md:text-6xl lg:text-7xl font-extrabold text-white mb-6 leading-[1.1] tracking-tight">
      <span class="inline-block">{title.split(' ').slice(0, -2).join(' ')}</span>{' '}
      <span class="bg-gradient-to-r from-primary-400 via-primary-300 to-accent-400 bg-clip-text text-transparent">
        {title.split(' ').slice(-2).join(' ')}
      </span>
    </h1>

    <p class="text-lg md:text-xl text-slate-400 mb-10 max-w-2xl mx-auto leading-relaxed">
      {subtitle}
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={ctaHref}
        class="inline-flex items-center gap-2 bg-gradient-to-r from-primary-500 to-primary-600 text-white font-semibold px-8 py-3.5 rounded-xl hover:from-primary-600 hover:to-primary-700 transition-all shadow-lg shadow-primary-500/25 hover:shadow-primary-500/40"
      >
        {ctaText}
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
      <a
        href="/a-propos"
        class="inline-flex items-center gap-2 text-slate-300 font-medium px-6 py-3.5 rounded-xl border border-white/10 hover:bg-white/5 transition-colors"
      >
        En savoir plus
      </a>
    </div>
  </div>
</section>
