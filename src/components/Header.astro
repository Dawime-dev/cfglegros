---
import { categories } from '../lib/categories';

const currentPath = Astro.url.pathname;

const navItems = [
  { label: 'Accueil', href: '/' },
  { label: 'Articles', href: '/articles' },
  ...Object.entries(categories).map(([key, cat]) => ({
    label: cat.label,
    href: `/categorie/${key}`,
  })),
];
---

<header class="bg-navy-900 sticky top-0 z-50 border-b border-white/10">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 group">
        <span class="w-9 h-9 bg-gradient-to-br from-primary-400 to-accent-500 rounded-lg flex items-center justify-center text-white font-extrabold text-sm tracking-tight shadow-lg shadow-primary-500/20">
          CL
        </span>
        <span class="text-white font-display font-bold text-lg tracking-tight">
          CLG <span class="text-primary-400">F. Legros</span>
        </span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden lg:block" aria-label="Navigation principale">
        <ul class="flex items-center gap-0.5">
          {navItems.map((item) => {
            const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
            return (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    'px-3 py-1.5 text-sm rounded-md transition-all duration-200',
                    isActive
                      ? 'text-white bg-white/10 font-semibold'
                      : 'text-slate-300 hover:text-white hover:bg-white/5',
                  ]}
                >
                  {item.label}
                </a>
              </li>
            );
          })}
        </ul>
      </nav>

      <!-- Mobile menu button -->
      <button
        type="button"
        class="lg:hidden p-2 text-slate-300 hover:text-white rounded-md hover:bg-white/10 transition-colors"
        aria-label="Ouvrir le menu"
        aria-expanded="false"
        id="mobile-menu-btn"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="menu-icon-open">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" id="menu-icon-close">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile nav -->
    <nav id="mobile-menu" class="hidden lg:hidden pb-4" aria-label="Navigation mobile">
      <ul class="flex flex-col gap-0.5 pt-2 border-t border-white/10">
        {navItems.map((item) => {
          const isActive = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
          return (
            <li>
              <a
                href={item.href}
                class:list={[
                  'block px-3 py-2.5 text-sm rounded-md transition-colors',
                  isActive
                    ? 'text-white bg-white/10 font-semibold'
                    : 'text-slate-300 hover:text-white hover:bg-white/5',
                ]}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');
  if (btn && menu && iconOpen && iconClose) {
    btn.addEventListener('click', () => {
      const isOpen = !menu.classList.contains('hidden');
      menu.classList.toggle('hidden');
      iconOpen.classList.toggle('hidden');
      iconClose.classList.toggle('hidden');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  }
</script>
